<?xml version="1.0" encoding="UTF-8"?>
<!--
    logback-test.xml
    Logback configuration for test execution.
    Console-only: no file appenders, no log directory required.
    Logback auto-discovers this file in the test classpath and uses it
    instead of logback-spring.xml during 'mvn test'.
-->
<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Suppress noisy framework logs during tests -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.flywaydb" level="WARN"/>
    <logger name="com.zaxxer.hikari" level="WARN"/>

    <!-- Court AI application logs at INFO during tests -->
    <logger name="com.courtai" level="INFO"/>

    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
